# ─── Database ───────────────────────────────────────────────
# PostgreSQL接続文字列
# ローカル: postgresql://postgres:password@localhost:5432/billing_pro
# Supabase: Settings > Database > Connection string (URI)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/billing_pro"

# ─── NextAuth ────────────────────────────────────────────────
# 本番URL（ローカルは http://localhost:3000）
NEXTAUTH_URL="http://localhost:3000"

# ランダム文字列: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"

# ─── Anthropic (OCR) ─────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Supabase Storage (PDF) ──────────────────────────────────
# Supabase > Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
# service_role key（サーバーサイドのみ。絶対にクライアントに渡さない）
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ─── Cron ────────────────────────────────────────────────────
# 期限超過バッチのシークレット（任意の文字列）
CRON_SECRET="your-cron-secret-here"

# ─── Resend (メール送信) ──────────────────────────────────────
# https://resend.com でAPIキー取得
RESEND_API_KEY="re_..."
# 送信元アドレス（Resendで認証済みドメインのアドレス）
EMAIL_FROM="BillingPro <noreply@yourdomain.co.jp>"

# ─── 発行元情報（PDF請求書に印字） ────────────────────────────
ISSUER_NAME="株式会社BillingPro"
ISSUER_ADDRESS="東京都千代田区〇〇1-2-3"
ISSUER_TEL="03-0000-0000"
ISSUER_EMAIL="billing@yourdomain.co.jp"
